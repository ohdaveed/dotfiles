{
  "env": {
    "MEM0_API_KEY": "{{ env \"MEM0_API_KEY\" }}",
    "GITHUB_TOKEN": "{{ env \"GITHUB_TOKEN\" }}"
  },
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "mem0@mem0-plugins": true
  },
  "extraKnownMarketplaces": {
    "mem0-plugins": {
      "source": {
        "source": "github",
        "repo": "mem0ai/mem0"
      }
    }
  },
  "effortLevel": "medium",
  "theme": "dark-daltonized",
  "editorMode": "normal",
  "verbose": true,
  "agentPushNotifEnabled": true
}

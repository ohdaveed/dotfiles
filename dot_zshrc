# 1. SPEED FLAGS (Must be at the top)
export ZSH_NVM_LAZY_LOAD=true
export ZSH_NVM_AUTOLOAD=false
export ZSH_NVM_AUTO_USE=false
export ZSH_DISABLE_COMPFIX="true"

# --- PATH CONFIGURATION ---
typeset -U path
path=(
  $HOME/bin 
  $HOME/.local/bin 
  $HOME/.bun/bin
  $HOME/.turso
  /usr/local/bin 
  $path
)
export PATH

# --- OH MY ZSH SETUP ---
export ZSH="$HOME/.oh-my-zsh"
plugins=(git zsh-better-npm-completion zsh-nvm rust sudo vscode zsh-autosuggestions zsh-syntax-highlighting)


# Load OMZ silently
source $ZSH/oh-my-zsh.sh > /dev/null 2>&1

# --- THEME (Oh My Posh) ---
if command -v oh-my-posh &> /dev/null; then
    eval "$(oh-my-posh init zsh --config $HOME/.config/oh-my-posh/easy-term.omp.json)"
fi

# --- CLAUDE-MEM & BUN ---
export BUN_INSTALL="$HOME/.bun"
# The alias we built for your specific path
alias claude-mem='bun "/home/parallax/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs"'

# --- NVM (Using your specific .config/nvm path) ---
export NVM_DIR="$HOME/.config/nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# --- ALIASES ---
alias python='uv run python'
alias zshconfig="code ~/.zshrc"
alias sfdph="cd ~/Documents/Work/Automation"
alias ..='cd ..'
alias pn=pnpm

# --- TERMINAL BEHAVIOR ---
export HISTSIZE=50000
export SAVEHIST=50000
setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE SHARE_HISTORY
# pnpm
export PNPM_HOME="/home/parallax/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# sqz — context intelligence layer (auto-installed)
sqz_run() {
    "$@" 2>&1 | SQZ_CMD="$*" sqz compress
}
sqz_sudo() {
    sudo "$@" 2>&1 | SQZ_CMD="sudo $*" sqz compress
}
preexec() {
    export __SQZ_CMD="$1"
}
# sqz — end of auto-installed block

export EDITOR=nano
export VISUAL="$EDITOR"
